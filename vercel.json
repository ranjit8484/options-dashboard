{
  "rewrites": [
    {
      "source": "/api/exec",
      "destination": "/api/exec"
    },
    {
      "source": "/api/alert",
      "destination": "/api/alert"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "functions": {
    "api/exec.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/alert.js": {
      "memory": 256,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/alert",
      "schedule": "0 14-21 * * 1-5"
    }
  ]
}
