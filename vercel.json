{
  "rewrites": [
    {
      "source": "/api/exec",
      "destination": "/api/exec"
    },
    {
      "source": "/api/alert-breach",
      "destination": "/api/alert-breach"
    },
    {
      "source": "/api/alert-signals",
      "destination": "/api/alert-signals"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "functions": {
    "api/exec.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/alert-breach.js": {
      "memory": 256,
      "maxDuration": 60
    },
    "api/alert-signals.js": {
      "memory": 256,
      "maxDuration": 60
    }
  },
  "crons": []
}
